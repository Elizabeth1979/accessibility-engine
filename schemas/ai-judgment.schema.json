{
  "$ref": "#/definitions/AIJudgment",
  "definitions": {
    "AIJudgment": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string"
        },
        "verdict": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL",
            "WARN",
            "UNKNOWN"
          ]
        },
        "reliability": {
          "type": "string",
          "enum": [
            "authoritative",
            "advisory"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "reason": {
          "type": "string"
        },
        "suggestedFix": {
          "type": "string"
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "schemaVersion",
        "verdict",
        "reliability",
        "confidence",
        "reason",
        "evidenceRefs"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
